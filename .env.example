# =============================================================================
# Neon PostgreSQL
# https://console.neon.tech → Project → Connection string
# =============================================================================
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# =============================================================================
# Neon MCP (Claude Code MCP サーバー用)
# https://console.neon.tech → Account → API Keys
# =============================================================================
NEON_API_KEY=

# =============================================================================
# Next.js
# =============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# Vercel (通常は vercel env pull .env.local で自動取得)
# https://vercel.com/docs/environment-variables
# =============================================================================
# VERCEL_URL=  # 自動設定されるため通常は不要

# =============================================================================
# CI / Build
# =============================================================================
# Set SKIP_ENV_VALIDATION=1 in CI when DATABASE_URL is not available at build time.
# SKIP_ENV_VALIDATION=
